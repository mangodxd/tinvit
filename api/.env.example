# Database URL (Render provides this automatically)
# For local dev: postgresql+asyncpg://postgres:123456@localhost:5432/newsdb
# For Render: DATABASE_URL is set by the platform
DATABASE_URL=postgresql+asyncpg://postgres:123456@localhost:5432/newsdb

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# CORS - Comma-separated list of allowed origins
# For production: https://your-app.vercel.app
CORS_ORIGINS=["http://localhost:3000"]

# Crawler settings
CRAWLER_TIMEOUT=30
LOG_LEVEL=INFO
