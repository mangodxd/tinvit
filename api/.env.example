# Database URL
# local dev: postgresql+asyncpg://postgres:123456@localhost:5432/newsdb
# production: Render sets DATABASE_URL automatically
DATABASE_URL=postgresql+asyncpg://postgres:123456@localhost:5432/newsdb

# API
API_HOST=0.0.0.0
API_PORT=8000

# CORS - add your frontend URL here for production
# local: ["http://localhost:3000"]
# production: ["https://your-app.vercel.app"]
CORS_ORIGINS=["http://localhost:3000"]

# Crawler
CRAWLER_TIMEOUT=30
LOG_LEVEL=INFO
